# Copy this file to .env and fill in values as needed.
#   cp .env.example .env
#
# This app uses a LOCAL Ollama model — no API key required!
# Just make sure Ollama is running: `ollama serve`

# Optional: override the default model (default: qwen2.5:latest)
# MODEL=phi3:latest

# Optional: override the Ollama endpoint (default: http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional: override the eval judge model (default: qwen2.5:latest)
# JUDGE_MODEL=qwen2.5:latest

# If you switch to hosted Gemini instead of local Ollama:
# GEMINI_API_KEY=your-key-here
