# Copy this file to .env and fill in your key. NEVER commit your real .env.
#   cp .env.example .env
#
# Use GEMINI_API_KEY for the hosted path (free tier: https://aistudio.google.com/),
# or leave it empty and point your backend at a local Ollama model instead.
GEMINI_API_KEY=your-key-here

# Optional: if serving locally via Ollama's OpenAI-compatible endpoint
# OLLAMA_BASE_URL=http://localhost:11434/v1
# MODEL=llama3.2:3b
